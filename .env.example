# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sports_inventory
DB_USER=postgres
DB_PASS=postgres

# JWT Security Configuration
JWT_SECRET=your_jwt_access_secret_key_here_must_be_long_and_secure
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_must_be_long_and_secure
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
